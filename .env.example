# ==========================================
# grAIn Backend - Environment Configuration
# ==========================================
# Copy this file to .env.local and fill in your values

# ==========================================
# Database
# ==========================================
MONGO_URI=mongodb://localhost:27017/grain
# For MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/grain?retryWrites=true&w=majority

# ==========================================
# Authentication & Security
# ==========================================
# Use a strong random string (min 32 characters) - CHANGE THIS!
JWT_SECRET=your-super-secure-jwt-secret-change-me-in-production

# ==========================================
# API Configuration
# ==========================================
# Base URL for Next.js API - defaults to '/api' (same-origin, works on any port)
# Only set this if the API is on a different host, e.g. http://api.example.com/api
# NEXT_PUBLIC_API_URL=

# ==========================================
# CORS - Configure for mobile & frontend apps
# ==========================================
# Admin Dashboard URL
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000

# Frontend/Expo App URL (for development)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ==========================================
# Firebase (Optional - for real-time updates)
# ==========================================
# NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=grain-640ed
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=grain-640ed.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
# NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ==========================================
# Expo Development Server
# ==========================================
# For Expo development, replace localhost with your computer IP
# Example for Mac on local network:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000/api

# For testing locally (development only):
# EXPO_PUBLIC_API_URL=http://localhost:3000/api

# ==========================================
# Email Configuration (Optional)
# ==========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ==========================================
# Logging & Debug
# ==========================================
NODE_ENV=development
DEBUG=grain:*

# ==========================================
# Feature Flags
# ==========================================
ENABLE_FIREBASE_REALTIME=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_ALERTS=false
